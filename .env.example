# 1) Получить токен у @BotFather
TELEGRAM_BOT_TOKEN=put_telegram_bot_token_here

# 2) NASA API key: https://api.nasa.gov/
# Для теста можно оставить DEMO_KEY, но у него ниже лимиты.
NASA_API_KEY=DEMO_KEY

# Часовой пояс для вывода событий и ручного добавления /addevent
BOT_TIMEZONE=Europe/Moscow

# SQLite база
DB_PATH=space_astro_bot.sqlite3

# Файл с первичными событиями. На старте бот загрузит их в SQLite.
EVENT_SEED_PATH=data/events.example.json

# Кто может добавлять/удалять события через /addevent и /delevent.
# Если оставить пустым, админ-команды доступны всем — удобно для теста, плохо для продакшена.
# Узнать свой chat_id можно командой /myid.
ADMIN_CHAT_IDS=

# Дополнительные источники новостей. Лучше указывать RSS, но бот умеет
# пробовать читать и HTML-страницы со списком новостей. Формат:
# EXTRA_RSS_SOURCES=Название|https://site.com/feed.xml;Другое название|https://site.com/news/
EXTRA_RSS_SOURCES=

NEWS_CHECK_INTERVAL_SECONDS=1800
PHOTO_CHECK_INTERVAL_SECONDS=21600
EVENT_CHECK_INTERVAL_SECONDS=1800
NEWS_MAX_PER_RUN=5

# Автоматическая загрузка событий из iCalendar.
# По умолчанию бот уже использует In-The-Sky.org:
# https://in-the-sky.org/newscalyear_ical.php?maxdiff=7&year={year}
# Можно добавить свои календари в формате:
# EVENT_ICS_SOURCES=Название|https://site.com/calendar.ics;Другое название|https://site.com/events-{year}.ics
EVENT_ICS_SOURCES=
EVENT_SYNC_INTERVAL_SECONDS=21600
EVENT_IMPORT_DAYS=370

# Автоматический перевод новостей и событий на русский.
# Бот хранит оригинал и русскую версию отдельно. Для перевода используется deep-translator.
TRANSLATION_ENABLED=true
TRANSLATION_TARGET_LANG=ru
TRANSLATION_MAX_CHARS=3500
TRANSLATION_MAX_ITEMS_PER_RUN=20
